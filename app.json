{
  "expo": {
    "name": "Serenity",
    "slug": "Serenity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "serenity",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "appleTeamId": "TL9UW7M88J",
      "bundleIdentifier": "com.msl.serenity",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.family-controls": true,
        "com.apple.security.application-groups": ["group.com.msl.serenity"]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-device-activity",
        {
          "appleTeamId": "TL9UW7M88J",
          "appGroup": "group.com.msl.serenity"
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.msl.serenity.ShieldConfiguration",
                  "targetName": "ShieldConfiguration",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.msl.serenity"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.msl.serenity.ShieldAction",
                  "targetName": "ShieldAction",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.msl.serenity"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "com.msl.serenity.ActivityMonitorExtension",
                  "targetName": "ActivityMonitorExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.msl.serenity"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "06c17db4-6c27-45ba-8387-4a83f8ff95d3"
      }
    }
  }
}
